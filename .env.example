GMAIL_OAUTH_CREDENTIALS_PATH=./secrets/gmail-oauth-client.json
GMAIL_TOKEN_PATH=./secrets/gmail-token.json
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook
POLL_INTERVAL_MS=60000
GMAIL_SENDER_FILTER=netflix.com
GMAIL_QUERY=in:inbox newer_than:1d
CHECKPOINT_PATH=./data/checkpoint.json
LOG_FILE_PATH=./output/app.log
GMAIL_FETCH_LIMIT=25
FORWARD_LATEST_COUNT=5
CHECKPOINT_MAX_IDS=250
